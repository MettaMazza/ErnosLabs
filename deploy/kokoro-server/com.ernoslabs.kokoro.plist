<?xml version="1.0" encoding="UTF-8"?>
<!-- Keep the warmed Kokoro ONNX service available for the public gateway. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ernoslabs.kokoro</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/mettamazza/.ernos/kokoro-venv/bin/python</string>
        <string>/Users/mettamazza/Desktop/ErnosLabs/deploy/kokoro-server/serve_local.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>StandardOutPath</key>
    <string>/tmp/kokoro-server.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/kokoro-server.log</string>
</dict>
</plist>
