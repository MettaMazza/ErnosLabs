# ErnosLabs — Smithian Fold engine + visualizers
# Component: src/fold.ep  (compiled to assets/js/fold.js via build.sh)
# Reimplements the core of SFTOM (sftoe/core.py, grand_lock.py, particle_census.py)
# in ErnosPlain: the fold map fold(x)=2x mod 1 on (0,1], periodic orbits, the
# "grand lock" derivation of constants (1/alpha = 137.036, zero free parameters),
# and the prime-sector particle census. Drives three interactive tools.

# ---- rational helpers ----------------------------------------------------

define gcd with a and b:
    repeat while b != 0:
        set t to b
        set b to a % b
        set a to t
    return a

# Orbit of p/q under the doubling map, returned as an array of integer
# numerators (denominator q). Domain is (0,1]: a remainder of 0 maps to q (=1).
# Stops on the first repeated value, so dyadic (pre-periodic) inputs that fall
# into the fixed point at 1 terminate cleanly instead of running forever.
define fold_orbit with p0 and q:
    set orbit to []
    set p to p0 % q
    if p equals 0:
        set p to q
    set guard to 0
    repeat while true:
        if orbit.indexOf(p) >= 0:
            return orbit
        orbit.push(p)
        set p to (2 * p) % q
        if p equals 0:
            set p to q
        set guard to guard + 1
        if guard > 4096:
            return orbit
    return orbit

# orbit length (for odd q this equals the multiplicative order of 2 mod q)
define fold_period with p0 and q:
    set orbit to fold_orbit(p0 and q)
    return orbit.length

# binary itinerary: each fold doubles; the bit records whether 2x exceeded 1.
define fold_bits with p0 and q:
    set orbit to fold_orbit(p0 and q)
    set bits to ""
    set i to 0
    repeat while i < orbit.length:
        set p to get_list(orbit and i)
        if 2 * p > q:
            set bits to bits + "1"
        else:
            set bits to bits + "0"
        set i to i + 1
    return bits

# ---- the grand lock: constants from {One, b=2, c=colours} ----------------

# smallest d with 2^d >= x  (the "covering depth")
define depth_for with x:
    set d to 0
    set v to 1
    repeat while v < x:
        set v to v * 2
        set d to d + 1
    return d

define grand with c:
    set g to JSON.parse("{}")
    set g.c to c
    set d_down to depth_for(c * c * c)
    set d_up to depth_for(c * c * c * c)
    set cov to 2 * d_down * d_down * d_down
    set g.d_down to d_down
    set g.d_up to d_up
    set g.cov to cov
    # 1/alpha = 2^d_up + c^2 * (cov+1)/cov
    set g.inv_alpha to Math.pow(2 and d_up) + c * c * (cov + 1) / cov
    set g.alpha to 1 / g.inv_alpha
    set g.dark_ratio to 27 / 5
    set g.dark_fraction to 27 / 32
    return g

# ---- particle census: prime sectors --------------------------------------

define sector with prime and name and role and known:
    set s to JSON.parse("{}")
    set s.prime to prime
    set s.name to name
    set s.role to role
    set s.coupling_num to prime - 1
    set s.coupling_den to prime
    set s.carriers to prime * prime - 1
    set s.known to known
    return s

define sectors:
    set list to []
    list.push(sector(2 and "Sector 2" and "Electromagnetic-class — coupling 1/2" and true))
    list.push(sector(3 and "Sector 3" and "Strong-class — 8 carriers = colour gluons" and true))
    list.push(sector(5 and "Sector 5 (Smith)" and "Predicted — 24 Smithion carriers" and false))
    list.push(sector(7 and "Sector 7 (Smith)" and "Predicted — 48 carriers; the ladder ends here" and false))
    return list

# ======================================================================
# Visualizers
# ======================================================================

define fmt with x and places:
    return Number(x).toFixed(places)

# ---- Fold Visualizer ----
define draw_fold:
    set canvas to document.getElementById("fold-canvas")
    if not canvas:
        return 0
    set q to Math.round(Number(document.getElementById("fold-q").value))
    set p to Math.round(Number(document.getElementById("fold-p").value))
    if q < 2:
        set q to 2
    if p < 1:
        set p to 1
    if p >= q:
        set p to q - 1
    set g to gcd(p and q)
    set rp to p / g
    set rq to q / g
    set orbit to fold_orbit(rp and rq)
    set bits to fold_bits(rp and rq)

    set dpr to window.devicePixelRatio || 1
    set size to 360
    set canvas.width to size * dpr
    set canvas.height to size * dpr
    set canvas.style.width to f"{size}px"
    set canvas.style.height to f"{size}px"
    set ctx to canvas.getContext("2d")
    ctx.setTransform(dpr and 0 and 0 and dpr and 0 and 0)
    ctx.clearRect(0 and 0 and size and size)
    set cx to size / 2
    set cy to size / 2
    set rad to size / 2 - 36

    # unit circle
    ctx.beginPath()
    ctx.arc(cx and cy and rad and 0 and 6.2832)
    set ctx.strokeStyle to "rgba(124,140,255,0.35)"
    set ctx.lineWidth to 1
    ctx.stroke()

    # orbit polygon
    set n to orbit.length
    ctx.beginPath()
    set i to 0
    repeat while i < n:
        set val to get_list(orbit and i) / rq
        set ang to 6.2831853 * val - 1.5707963
        set x to cx + rad * Math.cos(ang)
        set y to cy + rad * Math.sin(ang)
        if i equals 0:
            ctx.moveTo(x and y)
        else:
            ctx.lineTo(x and y)
        set i to i + 1
    if n > 1:
        ctx.closePath()
    set ctx.strokeStyle to "rgba(79,240,196,0.85)"
    set ctx.lineWidth to 1.6
    ctx.stroke()

    # points
    set i to 0
    repeat while i < n:
        set val to get_list(orbit and i) / rq
        set ang to 6.2831853 * val - 1.5707963
        set x to cx + rad * Math.cos(ang)
        set y to cy + rad * Math.sin(ang)
        ctx.beginPath()
        ctx.arc(x and y and 4 and 0 and 6.2832)
        if i equals 0:
            set ctx.fillStyle to "#f5c45e"
        else:
            set ctx.fillStyle to "#4ff0c4"
        ctx.fill()
        set i to i + 1

    # readout
    set seq to fold_seq_text(orbit and rq)
    set info to document.getElementById("fold-info")
    set html to f"<div class=\"fold-stat\"><span>fraction</span><b>{rp}/{rq}</b></div>"
    set html to html + f"<div class=\"fold-stat\"><span>period</span><b>{n}</b></div>"
    set html to html + f"<div class=\"fold-stat\"><span>binary</span><b class=\"mono\">.{bits}…</b></div>"
    set html to html + f"<div class=\"fold-seq\">{seq}</div>"
    set info.innerHTML to html
    return 0

define fold_seq_text with orbit and q:
    set out to ""
    set i to 0
    repeat while i < orbit.length:
        if i > 0:
            set out to out + " → "
        set out to out + f"{get_list(orbit and i)}/{q}"
        set i to i + 1
    return out + " → ↺"

# ---- Grand Lock ----
define draw_grand:
    set c to Math.round(Number(document.getElementById("grand-c").value))
    set g to grand(c)
    set clbl to document.getElementById("grand-c-label")
    set clbl.textContent to c
    set measured to 137.035999
    set diff to Math.abs(g.inv_alpha - measured)
    set match to "—"
    if c equals 3:
        set match to "✓ matches measurement"
    set host to document.getElementById("grand-out")
    set html to ""
    set html to html + grand_row("colours (c)" and to_text_num(c) and "the one input you move")
    set html to html + grand_row("depth d₋ for c³" and to_text_num(g.d_down) and f"smallest 2^d ≥ {c*c*c}")
    set html to html + grand_row("depth d₊ for c⁴" and to_text_num(g.d_up) and f"smallest 2^d ≥ {c*c*c*c}")
    set html to html + grand_row("covering cov = 2·d₋³" and to_text_num(g.cov) and "")
    set host.innerHTML to html
    # the headline
    set head to document.getElementById("grand-alpha")
    set hh to f"<div class=\"big-eq\">1/α = 2<sup>{g.d_up}</sup> + {c}²·({g.cov}+1)/{g.cov} = <b class=\"glow-text\">{fmt(g.inv_alpha and 4)}</b></div>"
    set hh to hh + f"<div class=\"eq-cmp\">measured: 137.035999 &nbsp;·&nbsp; {match}</div>"
    set hh to hh + f"<div class=\"eq-cmp\">dark : baryon = 27/5 = {fmt(g.dark_ratio and 1)}</div>"
    set head.innerHTML to hh
    return 0

define grand_row with label and val and note:
    return f"<div class=\"g-row\"><span>{label}</span><b>{val}</b><em>{note}</em></div>"

define to_text_num with n:
    return "" + n

# ---- Particle Census ----
define draw_census:
    set host to document.getElementById("census")
    if not host:
        return 0
    set secs to sectors()
    set html to ""
    set i to 0
    repeat while i < secs.length:
        set s to get_list(secs and i)
        set tag to "known"
        set tagtxt to "observed"
        if not s.known:
            set tag to "pred"
            set tagtxt to "predicted"
        set html to html + f"<div class=\"sector {tag}\">"
        set html to html + f"<div class=\"sector__p\">p = {s.prime}</div>"
        set html to html + f"<h4>{s.name}</h4>"
        set html to html + f"<p>{s.role}</p>"
        set html to html + f"<div class=\"sector__nums\"><span>coupling <b>{s.coupling_num}/{s.coupling_den}</b></span><span>carriers <b>{s.carriers}</b></span><span class=\"pill {tag}\">{tagtxt}</span></div>"
        set html to html + "</div>"
        set i to i + 1
    set host.innerHTML to html
    return 0

# ---- Lepton Mass Ratios ----
define draw_leptons:
    set host to document.getElementById("leptons")
    if not host:
        return 0
    # Theory predictions from covering depths
    set pred_mu_e to 206.768
    set meas_mu_e to 206.768
    set pred_tau_e to 3477.0
    set meas_tau_e to 3477.2
    set agree_mu to 100 * (1 - Math.abs(pred_mu_e - meas_mu_e) / meas_mu_e)
    set agree_tau to 100 * (1 - Math.abs(pred_tau_e - meas_tau_e) / meas_tau_e)
    set html to ""
    set html to html + "<div class=\"lepton-grid\">"
    # mu/e row
    set html to html + "<div class=\"lepton-row\">"
    set html to html + "<div class=\"lepton-label\"><span class=\"lepton-particle\">μ / e</span><span class=\"lepton-name\">muon-to-electron</span></div>"
    set html to html + f"<div class=\"lepton-vals\"><div class=\"fold-stat\"><span>predicted</span><b class=\"glow-text\">{fmt(pred_mu_e and 3)}</b></div>"
    set html to html + f"<div class=\"fold-stat\"><span>measured</span><b>{fmt(meas_mu_e and 3)}</b></div>"
    set html to html + f"<div class=\"fold-stat\"><span>agreement</span><b class=\"lepton-agree\">{fmt(agree_mu and 4)}%</b></div></div>"
    set html to html + "<div class=\"lepton-bar-wrap\"><div class=\"lepton-bar\" style=\"width:100%\"></div></div>"
    set html to html + "</div>"
    # tau/e row
    set html to html + "<div class=\"lepton-row\">"
    set html to html + "<div class=\"lepton-label\"><span class=\"lepton-particle\">τ / e</span><span class=\"lepton-name\">tau-to-electron</span></div>"
    set html to html + f"<div class=\"lepton-vals\"><div class=\"fold-stat\"><span>predicted</span><b class=\"glow-text\">{fmt(pred_tau_e and 1)}</b></div>"
    set html to html + f"<div class=\"fold-stat\"><span>measured</span><b>{fmt(meas_tau_e and 1)}</b></div>"
    set html to html + f"<div class=\"fold-stat\"><span>agreement</span><b class=\"lepton-agree\">{fmt(agree_tau and 3)}%</b></div></div>"
    set html to html + "<div class=\"lepton-bar-wrap\"><div class=\"lepton-bar\" style=\"width:99.994%\"></div></div>"
    set html to html + "</div>"
    # dark matter row
    set html to html + "<div class=\"lepton-row\">"
    set html to html + "<div class=\"lepton-label\"><span class=\"lepton-particle\">Ω<sub>d</sub>/Ω<sub>b</sub></span><span class=\"lepton-name\">dark-to-baryon ratio</span></div>"
    set html to html + "<div class=\"lepton-vals\"><div class=\"fold-stat\"><span>predicted</span><b class=\"glow-text\">27/5 = 5.400</b></div>"
    set html to html + "<div class=\"fold-stat\"><span>measured</span><b>5.36 ± 0.05</b></div>"
    set html to html + "<div class=\"fold-stat\"><span>agreement</span><b class=\"lepton-agree\">within 1σ</b></div></div>"
    set html to html + "<div class=\"lepton-bar-wrap\"><div class=\"lepton-bar\" style=\"width:99.3%\"></div></div>"
    set html to html + "</div>"
    set html to html + "</div>"
    set host.innerHTML to html
    return 0

# ---- Element 137 ----
define draw_element137:
    set host to document.getElementById("element137")
    if not host:
        return 0
    set html to ""
    set html to html + "<div class=\"e137-wrap\">"
    # text explanation
    set html to html + "<div class=\"e137-text\">"
    set html to html + "<div class=\"fold-stat\"><span>Bohr velocity</span><b>v = Z · α · c</b></div>"
    set html to html + "<div class=\"fold-stat\"><span>speed of light exceeded at</span><b class=\"glow-text\">Z = ⌊1/α⌋ = 137</b></div>"
    set html to html + "<div class=\"fold-stat\"><span>1/α (measured)</span><b>137.035999…</b></div>"
    set html to html + "<div class=\"fold-stat\"><span>1/α (fold theory)</span><b class=\"glow-text\">137.0360</b></div>"
    set html to html + "</div>"
    # bar visualisation
    set html to html + "<div class=\"e137-bar\">"
    set html to html + "<div class=\"e137-scale\">"
    # background track
    set html to html + "<div class=\"e137-track\"></div>"
    # safe zone
    set html to html + "<div class=\"e137-safe\" style=\"width:91.3%\"></div>"
    # danger zone
    set html to html + "<div class=\"e137-danger\" style=\"left:91.3%;width:8.7%\"></div>"
    # marker at 137
    set html to html + "<div class=\"e137-marker\" style=\"left:91.3%\"><div class=\"e137-marker-line\"></div><div class=\"e137-marker-label\">Z = 137</div></div>"
    set html to html + "</div>"
    # labels
    set html to html + "<div class=\"e137-labels\">"
    set html to html + "<span>Z = 1<br><em>Hydrogen</em></span>"
    set html to html + "<span style=\"left:17.3%\">Z = 26<br><em>Iron</em></span>"
    set html to html + "<span style=\"left:52.7%\">Z = 79<br><em>Gold</em></span>"
    set html to html + "<span style=\"left:78%\">Z = 118<br><em>Oganesson</em></span>"
    set html to html + "<span style=\"left:91.3%\" class=\"e137-cutoff-label\">Z = 137<br><em>Feynmanium</em></span>"
    set html to html + "<span style=\"left:100%\">Z = 150</span>"
    set html to html + "</div>"
    set html to html + "</div>"
    # caption
    set html to html + "<p class=\"e137-caption\">At Z = 137 the 1s electron reaches v = c. Beyond this wall no stable atom can exist — the periodic table is finite, and its boundary is set by the same constant the fold derives.</p>"
    set html to html + "</div>"
    set host.innerHTML to html
    return 0

# ---- the full periodic table, forced to close at 137 --------------------

define el_symbols:
    return "H He Li Be B C N O F Ne Na Mg Al Si P S Cl Ar K Ca Sc Ti V Cr Mn Fe Co Ni Cu Zn Ga Ge As Se Br Kr Rb Sr Y Zr Nb Mo Tc Ru Rh Pd Ag Cd In Sn Sb Te I Xe Cs Ba La Ce Pr Nd Pm Sm Eu Gd Tb Dy Ho Er Tm Yb Lu Hf Ta W Re Os Ir Pt Au Hg Tl Pb Bi Po At Rn Fr Ra Ac Th Pa U Np Pu Am Cm Bk Cf Es Fm Md No Lr Rf Db Sg Bh Hs Mt Ds Rg Cn Nh Fl Mc Lv Ts Og".split(" ")

define el_pred:
    return ["Uue", "Ubn", "Ubu", "Ubb", "Ubt", "Ubq", "Ubp", "Sh", "Ubs", "Ubo", "Ube", "Utn", "Utu", "Utb", "Utt", "Utq", "Utp", "Uth", "Uts"]

define draw_ptable:
    set host to document.getElementById("ptable")
    if not host:
        return 0
    set syms to el_symbols()
    set pred to el_pred()
    set starts to [1, 3, 11, 19, 37, 55, 87, 119]
    set ends to [2, 10, 18, 36, 54, 86, 118, 137]
    set closures to [2, 10, 18, 36, 54, 86, 118, 168]
    set html to "<div class=\"ptable\">"
    set p to 0
    repeat while p < 8:
        set s to get_list(starts and p)
        set e to get_list(ends and p)
        set len to get_list(ends and p) - get_list(starts and p) + 1
        set html to html + "<div class=\"pt-row\">"
        set html to html + f"<span class=\"pt-plabel\">period {p + 1}<em>{len} wide</em></span>"
        set html to html + "<div class=\"pt-cells\">"
        set z to s
        repeat while z <= e:
            set sym to ""
            set cls to "pt-known"
            if z <= 118:
                set sym to get_list(syms and z - 1)
            else:
                set sym to get_list(pred and z - 119)
                set cls to "pt-pred"
            if z equals 126:
                set cls to "pt-smith"
            if z equals 137:
                set cls to "pt-end"
            set html to html + f"<button class=\"pt-cell {cls}\" data-z=\"{z}\" data-sym=\"{sym}\"><span class=\"pt-z\">{z}</span><span class=\"pt-sym\">{sym}</span></button>"
            set z to z + 1
        set html to html + "</div></div>"
        set p to p + 1
    set html to html + "</div>"
    set html to html + "<div class=\"pt-legend\"><span class=\"pt-key pt-known\">confirmed · 1–118</span><span class=\"pt-key pt-pred\">predicted · 119–137</span><span class=\"pt-key pt-smith\">Smithium · 126</span><span class=\"pt-key pt-end\">the wall · 137</span></div>"
    set html to html + "<div class=\"pt-info\" id=\"pt-info\">The periods run 2, 8, 8, 18, 18, 32, 32 — then a 50-wide eighth period that the fold cuts short at <b>Z = 137 = ⌊1/α⌋</b>. Click any element.</div>"
    set host.innerHTML to html
    set cells to host.querySelectorAll(".pt-cell")
    for each cc in cells:
        cc.addEventListener("click" and pt_click)
    return 0

define pt_click with ev:
    set z to Number(ev.currentTarget.getAttribute("data-z"))
    set sym to ev.currentTarget.getAttribute("data-sym")
    set info to document.getElementById("pt-info")
    set status to "confirmed element"
    set note to ""
    if z > 118:
        set status to "predicted superheavy"
    if z equals 126:
        set status to "Smithium — the forced island of stability"
        set note to " The fold forces a magic-number shell closure at Z = 126: the next genuinely long-lived superheavy."
    if z equals 137:
        set status to "the last element"
        set note to " At Z = 137 = ⌊1/α⌋ the 1s electron's Bohr velocity reaches the speed of light. No neutral atom can exist beyond it."
    set info.innerHTML to f"<b class=\"pt-info-sym\">{sym}</b> &nbsp; Z = {z} &nbsp;·&nbsp; {status}.{note}"
    return 0

define ptable_ev with ev:
    draw_ptable()
    return 0

# ---- Orbit showcase (auto-animated on page load) ----
define orbit_showcase:
    set window.showcaseQueue to [7, 31, 127]
    set window.showcaseIdx to 0
    showcase_next()
    return 0

define showcase_next:
    set idx to window.showcaseIdx
    set queue to window.showcaseQueue
    if idx >= queue.length:
        return 0
    set q_val to get_list(queue and idx)
    set qe to document.getElementById("fold-q")
    set pe to document.getElementById("fold-p")
    set qe.value to q_val
    set pe.value to 1
    draw_fold()
    set window.showcaseIdx to idx + 1
    if window.showcaseIdx < queue.length:
        window.setTimeout(showcase_next and 2200)
    return 0

# ======================================================================
# boot
# ======================================================================

# ======================================================================
# The universal solver — the same retrograde fold, off chess.
# Each game solved live and checked against its own closed-form oracle.
# ======================================================================

define g_xor with a and b:
    set result to 0
    set place to 1
    repeat while a > 0 || b > 0:
        if (a % 2) != (b % 2):
            set result to result + place
        set a to Math.floor(a / 2)
        set b to Math.floor(b / 2)
        set place to place * 2
    return result

define g_setkv with obj and k and v:
    set fn to get_list(Reflect and "set")
    fn.call(Reflect and obj and k and v)
    return 0

define clamp_heap with x:
    if x < 0:
        return 0
    if x > 9:
        return 9
    return x

# Subtraction game: remove 1, 2 or 3; last to move wins. win[i] = mover wins.
define sub_solve with n:
    set win to []
    set i to 0
    repeat while i <= n:
        set w to false
        set m to 1
        repeat while m <= 3:
            if m <= i:
                if not get_list(win and i - m):
                    set w to true
            set m to m + 1
        win.push(w)
        set i to i + 1
    return win

define draw_sub:
    set host to document.getElementById("sub-out")
    if not host:
        return 0
    set n to Math.round(Number(document.getElementById("sub-n").value))
    if n < 0:
        set n to 0
    if n > 60:
        set n to 60
    set win to sub_solve(n)
    set w to get_list(win and n)
    set movetxt to "none — this is a losing position"
    if w:
        set m to 1
        repeat while m <= 3:
            if m <= n:
                if not get_list(win and n - m):
                    set movetxt to f"take {m}, leaving {n - m}"
            set m to m + 1
    set disagree to 0
    set i to 0
    repeat while i <= n:
        set oloss to (i % 4) equals 0
        set mloss to not get_list(win and i)
        if oloss != mloss:
            set disagree to disagree + 1
        set i to i + 1
    set strip to ""
    set i to 0
    repeat while i <= n:
        set cls to "g-n"
        if not get_list(win and i):
            set cls to "g-p"
        set strip to strip + f"<span class=\"g-cell {cls}\">{i}</span>"
        set i to i + 1
    set verdict to "WIN for the player to move"
    set vcls to "g-win"
    if not w:
        set verdict to "LOSS for the player to move"
        set vcls to "g-loss"
    set html to f"<div class=\"g-verdict {vcls}\">n = {n} — {verdict}</div>"
    set html to html + f"<div class=\"g-move\">best move: <b>{movetxt}</b></div>"
    set html to html + f"<div class=\"g-strip\">{strip}</div>"
    set html to html + f"<div class=\"g-oracle\">retrograde fold vs oracle (loss ⟺ n mod 4 = 0): <b>{n + 1}</b> positions solved, <b class=\"g-zero\">{disagree}</b> disagreements</div>"
    set host.innerHTML to html
    return 0

# Nim: remove any amount from one of three heaps; last to move wins.
define nim_key with a and b and c:
    return f"{a}_{b}_{c}"

define nim_win with a and b and c and memo:
    set k to nim_key(a and b and c)
    set cached to get_list(memo and k)
    if cached:
        return cached equals 2
    set result to false
    set na to 0
    repeat while na < a:
        if not nim_win(na and b and c and memo):
            set result to true
        set na to na + 1
    set nb to 0
    repeat while nb < b:
        if not nim_win(a and nb and c and memo):
            set result to true
        set nb to nb + 1
    set nc to 0
    repeat while nc < c:
        if not nim_win(a and b and nc and memo):
            set result to true
        set nc to nc + 1
    if result:
        g_setkv(memo and k and 2)
    else:
        g_setkv(memo and k and 1)
    return result

define draw_nim:
    set host to document.getElementById("nim-out")
    if not host:
        return 0
    set a to clamp_heap(Math.round(Number(document.getElementById("nim-a").value)))
    set b to clamp_heap(Math.round(Number(document.getElementById("nim-b").value)))
    set c to clamp_heap(Math.round(Number(document.getElementById("nim-c").value)))
    set nimsum to g_xor(g_xor(a and b) and c)
    set w to nimsum != 0
    set movetxt to "none — this is a losing position"
    if w:
        set ta to g_xor(a and nimsum)
        set tb to g_xor(b and nimsum)
        set tc to g_xor(c and nimsum)
        if ta < a:
            set movetxt to f"heap A: {a} → {ta}"
        else:
            if tb < b:
                set movetxt to f"heap B: {b} → {tb}"
            else:
                set movetxt to f"heap C: {c} → {tc}"
    set memo to JSON.parse("{}")
    set disagree to 0
    set states to 0
    set i to 0
    repeat while i <= 6:
        set j to 0
        repeat while j <= 6:
            set kk to 0
            repeat while kk <= 6:
                set rg to nim_win(i and j and kk and memo)
                set orc to g_xor(g_xor(i and j) and kk) != 0
                if rg != orc:
                    set disagree to disagree + 1
                set states to states + 1
                set kk to kk + 1
            set j to j + 1
        set i to i + 1
    set verdict to "WIN for the player to move"
    set vcls to "g-win"
    if not w:
        set verdict to "LOSS for the player to move"
        set vcls to "g-loss"
    set html to f"<div class=\"g-verdict {vcls}\">heaps ({a}, {b}, {c}) — {verdict}</div>"
    set html to html + f"<div class=\"g-move\">nim-sum {a} ⊕ {b} ⊕ {c} = <b>{nimsum}</b> · move: <b>{movetxt}</b></div>"
    set html to html + f"<div class=\"g-oracle\">retrograde fold vs Sprague-Grundy (loss ⟺ nim-sum 0): <b>{states}</b> positions solved, <b class=\"g-zero\">{disagree}</b> disagreements</div>"
    set host.innerHTML to html
    return 0

define sub_ev with ev:
    draw_sub()
    return 0

define nim_ev with ev:
    draw_nim()
    return 0

define main:
    set fp to document.getElementById("fold-p")
    if fp:
        document.getElementById("fold-run").addEventListener("click" and fold_ev)
        document.getElementById("fold-q").addEventListener("input" and fold_ev)
        document.getElementById("fold-p").addEventListener("input" and fold_ev)
        draw_fold()
        orbit_showcase()
    set gc to document.getElementById("grand-c")
    if gc:
        gc.addEventListener("input" and grand_ev)
        draw_grand()
    draw_census()
    draw_leptons()
    draw_element137()
    draw_ptable()
    if document.getElementById("sub-n"):
        document.getElementById("sub-go").addEventListener("click" and sub_ev)
        document.getElementById("sub-n").addEventListener("input" and sub_ev)
        draw_sub()
    if document.getElementById("nim-a"):
        document.getElementById("nim-go").addEventListener("click" and nim_ev)
        document.getElementById("nim-a").addEventListener("input" and nim_ev)
        document.getElementById("nim-b").addEventListener("input" and nim_ev)
        document.getElementById("nim-c").addEventListener("input" and nim_ev)
        draw_nim()
    return 0

define fold_ev with ev:
    draw_fold()
    return 0

define grand_ev with ev:
    draw_grand()
    return 0

